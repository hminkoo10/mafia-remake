DISCORD_TOKEN=
DISCORD_CLIENT_ID=123456789012345678
DISCORD_CLIENT_SECRET=your_client_secret_here

WEB_SETTINGS_HOST=0.0.0.0
WEB_SETTINGS_PORT=8800
WEB_SETTINGS_BASE_URL=https://your-domain.example.com

# ─── Discord Activity 서버 ───
# Activity API 서버 포트 (기본값: 8802)
ACTIVITY_PORT=8802

# 빌드된 프론트엔드 정적 파일 경로 (npm run build 후)
ACTIVITY_STATIC_DIR=activity/dist

# ─── 프론트엔드 전용 (activity/.env에 복사) ───
# VITE_CLIENT_ID=123456789012345678
# VITE_MOCK_GUILD_ID=987654321098765432  ← 로컬 개발용 mock guild ID