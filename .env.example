DISCORD_TOKEN=your_bot_token_here

# 레이트리밋 분산용 워커 봇 토큰(선택). 쉼표/공백/줄바꿈으로 여러 개 구분.
# 각 워커 봇은 게임을 진행할 서버에 초대되어 있어야 하고, "채널 관리 / 역할 관리 /
# 웹훅 관리" 권한과 관리 대상보다 높은 역할 위치가 필요하다. 채널 권한·채널 생성/삭제·
# 슬로우모드·역할 부여·웹훅 생성이 (메인+워커) 토큰으로 분산되어 예산이 (N+1)배가 된다.
# 슬래시/버튼 응답과 상태 메시지, 웹훅 실행은 항상 메인 토큰(DISCORD_TOKEN)이 처리한다.
# DISCORD_WORKER_TOKENS=worker_bot_token_1,worker_bot_token_2,worker_bot_token_3

WEB_SETTINGS_HOST=0.0.0.0
WEB_SETTINGS_PORT=8800
WEB_SETTINGS_BASE_URL=http://localhost:8800
# Cloudflare proxied HTTPS: do not use https://...:8880.
# Use 8443, 443, 2053, 2083, 2087, or 2096 instead.
# WEB_SETTINGS_PORT=8443
# WEB_SETTINGS_BASE_URL=https://example.com:8443
WEB_SETTINGS_TLS_CERT=/path/to/cert.pub
WEB_SETTINGS_TLS_KEY=/path/to/cert.key

ACTIVITY_PORT=2053
ACTIVITY_STATIC_DIR=/path/to/activity/dist
ACTIVITY_TLS_CERT=/path/to/cert.pub
ACTIVITY_TLS_KEY=/path/to/cert.key
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
